{
  "manifest_version": 2,
  "name": "leetcode-memory-leak-fix",
  "version": "1.0.0",
  "description": "reloads or discards leetcode tabs when site becomes unresponsive and slow",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "*://leetcode.com/*",
    "*://*.leetcode.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/*",
        "*://*.leetcode.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "browser_action": {
    "default_title": "leetcode-memory-leak-fix"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "leetcode-memory-leak-fix@example.local",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
